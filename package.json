{
  "name": "swalha-cad",
  "version": "0.0.0",
  "private": true,
  "description": "Browser-based parametric CAD designed for humans and AI agents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --if-present --parallel run dev",
